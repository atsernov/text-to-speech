# SQLite database — each developer creates their own via: php artisan migrate
/database/*.sqlite
/database/*.sqlite-shm
/database/*.sqlite-wal

# User-generated audio files — not part of the codebase
/storage/app/public/audio/*
!/storage/app/public/audio/.gitkeep

# Voice preview samples — regenerated via: php artisan voices:refresh
/storage/app/public/voice-samples/*
!/storage/app/public/voice-samples/.gitkeep

# General storage uploads
/storage/app/private/*
!/storage/app/private/.gitkeep
